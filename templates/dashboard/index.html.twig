{% extends 'base.html.twig' %}

{% block title %}Hello DashboardController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h1>Hello {{ controller_name }}! ✅</h1>

    This friendly message is coming from:
    <ul>
        {{dump(request)}}
        <li>Your controller at <code>/Users/brendantuckerman/Projects/htmx-training/src/Controller/DashboardController.php</code></li>
        <li>Your template at <code>/Users/brendantuckerman/Projects/htmx-training/templates/dashboard/index.html.twig</code></li>
    </ul>
  <div id="parent-div">
    <button hx-get="/clicked"
    hx-trigger="click"
    hx-target="#parent-div"
    hx-swap="outerHTML">
    Click Me!
</button>
</div>
</div>
{% endblock %}
